[global]
monitor = 0
follow = mouse
width = 200
height = 150
origin = bottom-right
offset = 5x25
corner_radius = 0
scale = 0
notification_limit = 0
progress_bar = true
progress_bar_height = 10
progress_bar_frame_width = 0
progress_bar_width = 200
indicate_hidden = yes
transparency = 0
separator_height = 1
padding = 10
text_icon_padding = 0
frame_width = 2
gap_size = 0
separator_color = frame
sort = yes
idle_threshold = 120
font = monospace bold 8
line_height = 1
markup = full
format = %s\n%b
alignment = left
vertical_alignment = center
show_age_threshold = 60
ellipsize = middle
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes
enable_recursive_icon_lookup = true
icon_position = left
min_icon_size = 24
max_icon_size = 24
sticky_history = yes
history_length = 20
browser = /usr/bin/xdg-open
always_run_script = true
mouse_left_click = close_current
mouse_right_click = do_action, close_current
title = Dunst
class = Dunst

[urgency_low]
timeout = 2
background = "#2D333F"
foreground = "#D8DEE9"
frame_color = "#81A1C1"

[urgency_normal]
timeout = 5
background = "#2D333F"
foreground = "#D8DEE9"
frame_color = "#81A1C1"

[urgency_critical]
timeout = 0
background = "#2D333F"
foreground = "#D8DEE9"
frame_color = "#BF616A"
