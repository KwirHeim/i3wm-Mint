general {
    colors = true
    color_good = "#A3BE8C"
    color_degraded = "#EBCB8B"
    color_bad = "#BF616A"
    interval = 1
}

order += "wireless _first_"
order += "volume master"
order += "battery 0"
order += "memory"
order += "cpu_usage"
order += "cpu_temperature 0"
#order += "load"
order += "tztime local"

volume master {
    format = "V%volume"
    format_muted = "Muted"
}

battery 0 {
    format = "B%percentage%status"
    hide_seconds = true
    integer_battery_capacity = true
    last_full_capacity = true
    status_chr = "↑"
    status_bat = "↓"
    status_full = ""
}

wireless _first_ {
    format_up = "%essid"
    format_down = "DISCONNECT"
}

memory {
    memory_used_method = "memavailable"
    format = "%used"
    decimals = 2
}

cpu_usage {
    format = "%usage"
}

load { 
    format = "%1min/%5min/%15min"
}

cpu_temperature 0 {
    format = "%degrees°C"
}

tztime local {
    format = "%H:%M:%S"
}

