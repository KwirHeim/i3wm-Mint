color-link default "white"
color-link comment "brightblack"
color-link identifier "white"
color-link constant "yellow"
color-link statement "blue"
color-link string "green"
color-link error "bold red"
color-link todo "bold magenta"
color-link tabbar "black,blue"
color-link statusline "black,blue"
color-link line-number "brightblack"
#color-link cursor-line ""
